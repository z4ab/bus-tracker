# =============================================================================
# Bus Tracker - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Variables marked (REQUIRED) must be set for the application to start.
# Variables marked (optional) have sensible defaults or gracefully degrade.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend: GTFS-Realtime Feeds
# ---------------------------------------------------------------------------

# (REQUIRED) URL for the GRT bus GTFS-realtime vehicle positions feed.
# This is the primary data source for real-time bus locations.
GRT_VEHICLE_POSITIONS_URL=

# (optional) URL for the GRT GTFS-realtime trip updates feed.
# Used to get real-time schedule deviations and cancellations.
GRT_TRIP_UPDATES_URL=

# (optional) URL for the GRT GTFS-realtime alerts feed.
# Used to get service alerts, detours, and disruptions.
GRT_ALERTS_URL=

# (REQUIRED) URL for the GRT static GTFS schedule ZIP archive.
# Used to build the route/stop database for lookups.
GRT_GTFS_STATIC_URL=

# (optional) URL for the LRT (Ion light rail) GTFS-realtime vehicle positions feed.
LRT_VEHICLE_POSITIONS_URL=

# (optional) URL for the LRT (Ion light rail) GTFS-realtime trip updates feed.
LRT_TRIP_UPDATES_URL=

# (optional) URL for the LRT (Ion light rail) static GTFS schedule ZIP archive.
LRT_GTFS_STATIC_URL=

# ---------------------------------------------------------------------------
# Backend: Cache & Performance
# ---------------------------------------------------------------------------

# (optional) How often (in seconds) the in-memory GTFS-realtime cache refreshes.
# Defaults to 30 if unset.
# REFRESH_SECONDS=30

# (optional) Directory path for the SQLite GTFS static cache database.
# Defaults to ~/.cache/bus-tracker if unset.
# GTFS_CACHE_DIR=

# ---------------------------------------------------------------------------
# Backend: Security & CORS
# ---------------------------------------------------------------------------

# (optional) When set to "true" (or "1"/"yes"/"on"), allows weak TLS
# connections for GRT feeds. Useful for testing with self-signed certs.
# Defaults to "false".
# GRT_ALLOW_WEAK_TLS=false

# (optional) Additional frontend origin URL allowed for CORS.
# The app already allows localhost:5173 and the Vercel production URL.
# Set this to your deployed frontend URL if different.
# FRONTEND_ORIGIN=

# (optional) Comma-separated list of additional CORS-allowed origins.
# Overrides or extends the default allowed origins list.
# CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# (optional) Base URL for the Vite dev server proxy.
# Set this when the frontend needs to reach the API at a custom address.
# Defaults to proxying through the Vite dev server if unset.
# VITE_API_BASE_URL=
