# Backend (FastAPI)
# GRT (Bus) - Replace the values below with actual GTFS endpoints.
GRT_VEHICLE_POSITIONS_URL=REPLACE_WITH_VEHICLE_POSITIONS_URL
GRT_GTFS_STATIC_URL=REPLACE_WITH_GTFS_STATIC_URL

# Optional GRT feeds
GRT_TRIP_UPDATES_URL=
GRT_ALERTS_URL=

# LRT (Light Rail Transit) - Optional feeds
LRT_VEHICLE_POSITIONS_URL=
LRT_TRIP_UPDATES_URL=
LRT_GTFS_STATIC_URL=

# Refresh interval (seconds)
REFRESH_SECONDS=30

# TLS
GRT_ALLOW_WEAK_TLS=false

# Frontend (Vite)
# API base URL for the FastAPI service.
VITE_API_BASE_URL=http://localhost:8000
